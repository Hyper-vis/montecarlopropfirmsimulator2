import numpy as np
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt

from apex_engine_v3_1 import (
    load_daily_pnl,
    simulate_path,
    ACCOUNT_SIZE,
    TRAILING_DD,
    TRAIL_STOP_LEVEL,
    DAILY_LOSS_LIMIT,
    DAILY_PROFIT_CAP,
    PAYOUT_THRESHOLD,
    MAX_PAYOUT,
)

# ---------------------------------------------------------------------------
# Input helpers
# ---------------------------------------------------------------------------

def ask_int(prompt, default=None):
    while True:
        raw = input(prompt).strip()
        if raw == "" and default is not None:
            return default
        try:
            return int(raw)
        except ValueError:
            print("  Please enter a whole number.")


def ask_float(prompt, default=None):
    while True:
        raw = input(prompt).strip()
        if raw == "" and default is not None:
            return default
        try:
            return float(raw)
        except ValueError:
            print("  Please enter a numeric value.")


def ask_yes_no(prompt):
    while True:
        raw = input(prompt).strip().lower()
        if raw in ("yes", "y"):
            return True
        if raw in ("no", "n"):
            return False
        print("  Please answer yes or no.")


# ---------------------------------------------------------------------------
# CSV + account count
# ---------------------------------------------------------------------------

csv_path = input("Enter CSV filename (must be in this folder): ").strip()
if not csv_path.endswith(".csv"):
    csv_path += ".csv"

# v3 engine: loads empirical daily PnL in dollars (no ratio conversion)
daily_pnl = load_daily_pnl(csv_path)

n_accounts = ask_int("Number of accounts: ")

# ---------------------------------------------------------------------------
# Settings
# ---------------------------------------------------------------------------
# v3 note: account geometry (ACCOUNT_SIZE, TRAILING_DD, PAYOUT_THRESHOLD, etc.)
# is fixed by apex_engine_v3 module-level constants.
# Configurable here: risk_multiplier, max_days, stop_at_payout.

use_apex = ask_yes_no("Use default Apex settings? (yes/no): ")

if use_apex:
    max_days         = 30
    stop_at_payout   = True
    risk_multiplier  = 1.0
    n_sims           = 10000
    sampling_mode    = "uniform"
    weight_strength  = 3.0
    recent_window    = 50
else:
    print()
    print("  NOTE: Account geometry (size, drawdown limits, thresholds) is fixed")
    print("        by Apex constants in apex_engine_v3_1. Configurable below:")
    print()
    max_days         = ask_int("Max days per account cycle: ", default=30)
    stop_at_payout   = ask_yes_no("Stop each account at first payout? (yes/no): ")
    risk_multiplier  = ask_float("Risk multiplier (1.0 = no change): ", default=1.0)
    n_sims           = ask_int("Number of Monte Carlo simulations: ", default=10000)
    print("  Sampling mode: uniform / recency_weighted / recent_only")
    sampling_mode    = input("  Sampling mode [uniform]: ").strip() or "uniform"
    weight_strength  = 3.0
    recent_window    = 50
    if sampling_mode == "recency_weighted":
        weight_strength = ask_float("  Weight strength (3=moderate, 6=strong): ", default=3.0)
    elif sampling_mode == "recent_only":
        recent_window   = ask_int("  Recent window (trading days): ", default=50)

# Expose constants used later in charts / printout
account_size      = ACCOUNT_SIZE
trailing_dd       = TRAILING_DD
tail_stop_level   = TRAIL_STOP_LEVEL
daily_loss_limit  = DAILY_LOSS_LIMIT
daily_profit_cap  = DAILY_PROFIT_CAP
payout_threshold  = PAYOUT_THRESHOLD
max_payout        = MAX_PAYOUT

# ---------------------------------------------------------------------------
# Portfolio simulation
# ---------------------------------------------------------------------------

print(f"\nRunning {n_sims:,} simulations across {n_accounts} account(s)...\n")

PATH_SIMS = 150  # number of simulation runs from which to collect equity paths

portfolio_payouts    = np.zeros(n_sims)
portfolio_blowouts   = np.zeros(n_sims, dtype=int)
# track ending balance per account so we can average across sims
account_end_balances = np.zeros((n_sims, n_accounts))
# track days-to-payout per account per sim (NaN = no payout that run)
account_payout_days  = np.full((n_sims, n_accounts), np.nan)

# account_paths[i] = list of (equity_path, outcome) for account slot i
account_paths = [[] for _ in range(n_accounts)]

for sim in range(n_sims):
    total_payout = 0.0
    blown_count  = 0

    for acct_idx in range(n_accounts):
        result = simulate_path(
            daily_pnl,
            risk_multiplier = risk_multiplier,
            max_days        = max_days,
            stop_at_payout  = stop_at_payout,
            mode            = sampling_mode,
            weight_strength = weight_strength,
            recent_window   = recent_window,
        )
        total_payout += result["payout"]
        account_end_balances[sim, acct_idx] = result["balance"]
        if result["outcome"] == "blow":
            blown_count += 1
        if result["outcome"] == "payout":
            account_payout_days[sim, acct_idx] = result["days"]
        if sim < PATH_SIMS:
            account_paths[acct_idx].append((result["equity_path"], result["outcome"]))

    portfolio_payouts[sim]  = total_payout
    portfolio_blowouts[sim] = blown_count

# ---------------------------------------------------------------------------
# Results
# ---------------------------------------------------------------------------

mean_end_per_acct = account_end_balances.mean(axis=0)  # shape (n_accounts,)
mean_end_portfolio = mean_end_per_acct.sum()
mean_end_single    = mean_end_per_acct.mean()

print("=" * 52)
print(f"  Portfolio size:            {n_accounts} account(s)")
print(f"  Window:                    {max_days} days (stop at payout)")
print(f"  Monte Carlo simulations:   {n_sims:,}")
print("-" * 52)
print(f"  Mean total payout:         ${np.mean(portfolio_payouts):>12,.2f}")
print(f"  Median total payout:       ${np.median(portfolio_payouts):>12,.2f}")
print(f"  5th percentile payout:     ${np.percentile(portfolio_payouts, 5):>12,.2f}")
print(f"  95th percentile payout:    ${np.percentile(portfolio_payouts, 95):>12,.2f}")
print(f"  Prob total payout > 0:     {(portfolio_payouts > 0).mean():>12.2%}")
print(f"  Mean blown accounts:       {np.mean(portfolio_blowouts):>12.2f} / {n_accounts}")
print("-" * 52)
print(f"  Mean ending bal (single):  ${mean_end_single:>12,.2f}")
print(f"  Mean ending bal (total):   ${mean_end_portfolio:>12,.2f}")
if n_accounts > 1:
    for i, bal in enumerate(mean_end_per_acct):
        print(f"    Account {i+1}:              ${bal:>12,.2f}")
print("=" * 52)

# ---------------------------------------------------------------------------
# Cycle efficiency analysis
# ---------------------------------------------------------------------------

TRADING_DAYS_PER_MONTH = 21   # ~6 days/week × ~3.5 weeks
CYCLE_GATE             = 8    # Apex minimum trading days before payout

all_payout_days = account_payout_days.flatten()
all_payout_days = all_payout_days[~np.isnan(all_payout_days)]  # keep only payouts

if len(all_payout_days) > 0:
    pct_within_gate   = (all_payout_days <= CYCLE_GATE).mean()
    pct_within_10     = (all_payout_days <= 10).mean()
    pct_within_15     = (all_payout_days <= 15).mean()
    mean_days_payout  = all_payout_days.mean()
    median_days_payout= np.median(all_payout_days)
    p5_days           = np.percentile(all_payout_days, 5)
    p95_days          = np.percentile(all_payout_days, 95)

    # Estimated cycles per month assuming accounts restart immediately after payout
    est_cycles        = TRADING_DAYS_PER_MONTH / mean_days_payout
    payout_prob_single= len(all_payout_days) / (n_sims * n_accounts)
    est_monthly_gross = n_accounts * est_cycles * payout_prob_single * np.mean(
                            [r for r in portfolio_payouts if r > 0] or [0]
                        ) / n_accounts  # per-account avg payout scaled
    # simpler: mean payout per account per cycle × cycles × accounts
    mean_payout_per_hit = np.mean([p for p in account_payout_days.flatten()
                                   if not np.isnan(p)] or [0])  # reuse days proxy
    # Actually compute mean payout amount directly
    all_acct_payouts = []
    for sim in range(n_sims):
        for acct_idx in range(n_accounts):
            if not np.isnan(account_payout_days[sim, acct_idx]):
                # Extract individual payout: total - other accounts not straightforward
                pass  # use portfolio mean / n_accounts as proxy
    mean_payout_per_acct_hit = np.mean(portfolio_payouts) / (n_accounts * payout_prob_single) if payout_prob_single > 0 else 0
    est_monthly_gross = n_accounts * est_cycles * payout_prob_single * mean_payout_per_acct_hit

    print(f"\n{'=' * 52}")
    print(f"  Cycle Efficiency  (Apex min gate = {CYCLE_GATE} trading days)")
    print(f"  Trading days/month assumed: {TRADING_DAYS_PER_MONTH}")
    print(f"{'=' * 52}")
    print(f"  Payout prob per cycle:     {payout_prob_single:>12.2%}")
    print(f"  Mean days to payout:       {mean_days_payout:>12.1f} trading days")
    print(f"  Median days to payout:     {median_days_payout:>12.1f} trading days")
    print(f"  5th pct days to payout:    {p5_days:>12.1f} trading days")
    print(f"  95th pct days to payout:   {p95_days:>12.1f} trading days")
    print(f"{'-' * 52}")
    print(f"  Hit within {CYCLE_GATE} days (min gate): {pct_within_gate:>10.2%}")
    print(f"  Hit within 10 days:        {pct_within_10:>12.2%}")
    print(f"  Hit within 15 days:        {pct_within_15:>12.2%}")
    print(f"{'-' * 52}")
    print(f"  Est. cycles/month/account: {est_cycles:>12.2f}")
    print(f"  Est. monthly gross ({n_accounts} accts): ${est_monthly_gross:>11,.2f}")
    print(f"  Est. monthly net (fees):   ${est_monthly_gross - (n_accounts * est_cycles * (1 - payout_prob_single) * 214.50):>11,.2f}")
    print(f"{'=' * 52}")
else:
    print("\n  No payouts recorded — cycle analysis unavailable.")

# ---------------------------------------------------------------------------
# Histogram
# ---------------------------------------------------------------------------

fig, ax = plt.subplots(figsize=(10, 6))

ax.hist(portfolio_payouts, bins=50, color="steelblue", edgecolor="white", linewidth=0.5)
ax.axvline(np.mean(portfolio_payouts),   color="orange", linestyle="--", linewidth=1.5, label=f"Mean ${np.mean(portfolio_payouts):,.0f}")
ax.axvline(np.median(portfolio_payouts), color="green",  linestyle="--", linewidth=1.5, label=f"Median ${np.median(portfolio_payouts):,.0f}")

ax.set_title(f"Portfolio Payout Distribution — {n_accounts} Account(s), {n_sims:,} Simulations", fontsize=13)
ax.set_xlabel("Total Portfolio Payout ($)", fontsize=11)
ax.set_ylabel("Frequency", fontsize=11)
ax.legend(fontsize=10)
ax.grid(axis="y", alpha=0.3)

plt.tight_layout()
plt.savefig("multi_account_histogram.png", dpi=150)
plt.close(fig)

print("Histogram saved to: multi_account_histogram.png")

# ---------------------------------------------------------------------------
# Equity path grid  (one subplot per account, up to 9 shown)
# ---------------------------------------------------------------------------

OUTCOME_STYLE = {
    "payout":  {"color": "#2ecc71", "alpha": 0.30, "zorder": 2},
    "blow":    {"color": "#e74c3c", "alpha": 0.30, "zorder": 2},
    "timeout": {"color": "#95a5a6", "alpha": 0.20, "zorder": 1},
}

n_shown   = min(n_accounts, 9)
n_cols    = min(n_shown, 3)
n_rows    = (n_shown + n_cols - 1) // n_cols
fig_w     = max(6, n_cols * 4)
fig_h     = max(4, n_rows * 3.2)

fig2, axes = plt.subplots(n_rows, n_cols, figsize=(fig_w, fig_h), squeeze=False)

for plot_idx in range(n_rows * n_cols):
    row, col = divmod(plot_idx, n_cols)
    ax2 = axes[row][col]

    if plot_idx >= n_shown:
        ax2.set_visible(False)
        continue

    paths_for_acct = account_paths[plot_idx]

    # Count outcomes for subtitle
    outcome_counts = {k: 0 for k in OUTCOME_STYLE}
    for path, outcome in paths_for_acct:
        style = OUTCOME_STYLE.get(outcome, OUTCOME_STYLE["timeout"])
        ax2.plot(path, linewidth=0.7, **style)
        outcome_counts[outcome] = outcome_counts.get(outcome, 0) + 1

    # Reference lines
    ax2.axhline(payout_threshold,  color="#27ae60", linestyle="--", linewidth=0.9, alpha=0.8)
    ax2.axhline(account_size,      color="#2980b9", linestyle="--", linewidth=0.9, alpha=0.8)
    ax2.axhline(account_size - trailing_dd, color="#c0392b", linestyle="--", linewidth=0.9, alpha=0.8)

    n_p = outcome_counts.get("payout", 0)
    n_b = outcome_counts.get("blow", 0)
    n_t = outcome_counts.get("timeout", 0)
    ax2.set_title(
        f"Account {plot_idx + 1}\n"
        f"Pay {n_p}  Blow {n_b}  Time {n_t}",
        fontsize=8, pad=3
    )
    ax2.tick_params(labelsize=7)
    ax2.yaxis.set_major_formatter(plt.FuncFormatter(lambda v, _: f"${v:,.0f}"))
    ax2.grid(alpha=0.2)

# Shared legend
from matplotlib.lines import Line2D
legend_elements = [
    Line2D([0], [0], color="#2ecc71", linewidth=1.5, label="Payout"),
    Line2D([0], [0], color="#e74c3c", linewidth=1.5, label="Blow"),
    Line2D([0], [0], color="#95a5a6", linewidth=1.5, label="Timeout"),
    Line2D([0], [0], color="#27ae60", linewidth=1.2, linestyle="--", label="Payout threshold"),
    Line2D([0], [0], color="#2980b9", linewidth=1.2, linestyle="--", label="Account size"),
    Line2D([0], [0], color="#c0392b", linewidth=1.2, linestyle="--", label="Max draw floor"),
]
fig2.legend(handles=legend_elements, loc="lower center", ncol=3, fontsize=8,
            bbox_to_anchor=(0.5, 0), framealpha=0.9)

if n_shown < n_accounts:
    fig2.suptitle(
        f"Equity Paths — First {n_shown} of {n_accounts} Accounts  "
        f"(sample of {PATH_SIMS} simulations each)",
        fontsize=11, y=1.01
    )
else:
    fig2.suptitle(
        f"Equity Paths — {n_accounts} Account(s)  "
        f"(sample of {PATH_SIMS} simulations each)",
        fontsize=11, y=1.01
    )

plt.tight_layout(rect=[0, 0.07, 1, 1])
plt.savefig("multi_account_paths.png", dpi=150, bbox_inches="tight")
plt.close(fig2)

print("Equity path grid saved to: multi_account_paths.png")
